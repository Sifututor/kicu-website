---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "KICU — Your Malaysian Tax Sidekick",
  description = "Track Malaysian tax relief receipts, maximize your claims, and file with confidence. KICU helps you snap receipts, categorize them into LHDN categories, and monitor your savings."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#157DEC" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_MY" />

    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-white">
    <slot />
  </body>
</html>
